# Firebase Console > 프로젝트 설정 > 일반 > 웹 앱 — 아래 7줄을 Vercel에 통째로 붙여넣기

FIREBASE_API_KEY=YOUR_API_KEY
# 도메인 (authDomain) — 예: project-todo-backend.firebaseapp.com
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# DB 주소 (databaseURL) — Realtime Database
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# FIREBASE_AUTH_DOMAIN 대신 FIREBASE_DOMAIN 이름만 써도 됩니다.
